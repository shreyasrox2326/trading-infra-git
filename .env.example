# Cloudflare R2 S3 API credentials
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key

# Cloudflare "S3 API" base URL only. Do NOT include the bucket name suffix.
# Example: https://your-account-id.r2.cloudflarestorage.com
R2_S3_API=https://your-account-id.r2.cloudflarestorage.com

# Cloudflare bucket name
R2_BUCKET_NAME=trading-infra-prod
R2_REGION=auto
